;
; RzDevU_00b9_Kbd2.inf
;

[Version]
Signature   = "$WINDOWS NT$"
Class       = Keyboard
ClassGuid   = {4D36E96B-E325-11CE-BFC1-08002BE10318}
Provider    = %ManufacturerName%
CatalogFile = rzdev_00b9_kbd2.cat
DriverVer = 01/11/2023,10.0.15063.0
PnpLockdown=1

[DestinationDirs]
DefaultDestDir = 12

[SourceDisksNames]
1 = %DiskName%,,,""

[SourceDisksFiles]
RzDev_00b9.sys  = 1,,

;*****************************************
; Install Section
;*****************************************

[Manufacturer]
%ManufacturerName%=Standard,NTamd64

[Standard.NTamd64]
%RzDev.DeviceDesc%=RzDev_Device,         HID\Vid_1532&Pid_00b9&MI_01&Col01

[RzDev_Device.NT]
Include = keyboard.inf
Needs = HID_Keyboard_Inst.NT
CopyFiles=Drivers_Dir

[Drivers_Dir]
RzDev_00b9.sys

[RzDev_Device.NT.HW]
Include=keyboard.inf
Needs=HID_Keyboard_Inst.NT.HW
AddReg = RzDev_Device.NT.HW.AddReg

[RzDev_Device.NT.HW.AddReg]  
HKR,,"UpperFilters",0x00010000,"RzDev_00b9"
HKR,,"Kbd2Device",0x00010001,1
;; FILE_DEVICE_SECURE                         
HKR,,DeviceCharacteristics,0x10001,0x0100         ; Use same security checks on relative opens
; SDDL_DEVOBJ_SYS_ALL_ADM_RWX_WORLD_RWX_RES_RWX
HKR,,Security,,"D:P(A;;GA;;;SY)(A;;GRGWGX;;;BA)(A;;GRGWGX;;;WD)(A;;GRGWGX;;;RC)"

;-------------- Service installation
[RzDev_Device.NT.Services]
AddService = RzDev_00b9,, RzDev_Service_Inst
Include=keyboard.inf
Needs=HID_Keyboard_Inst.NT.Services

; -------------- RzDev driver install sections
[RzDev_Service_Inst]
DisplayName    = %RzDev.ServiceDesc%
ServiceType    = 1               ; SERVICE_KERNEL_DRIVER
StartType      = 3               ; SERVICE_DEMAND_START
ErrorControl   = 1               ; SERVICE_ERROR_NORMAL
ServiceBinary  = %12%\RzDev_00b9.sys

[Strings]
ManufacturerName="Razer Inc"
DiskName = "Razer 00b9 Installation Disk"
RzDev.ServiceDesc= "Razer 00b9 Service"
RzDev.DeviceDesc = "HID Keyboard Device"
